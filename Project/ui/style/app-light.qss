/* 
 * Rodent Refreshment Regulator - Light Theme
 * Enhanced with subtle depth, modern aesthetics, and visual hierarchy
 */

/* Global defaults */
* {
    font-family: "DejaVu Sans", "Noto Sans", sans-serif;
    font-size: 13px;
}

QWidget {
    background-color: #F5F3EF;   /* Warm cream base matching inspiration */
    color: #131313;              /* high-contrast text */
}

/* Cards (surface containers with elevation) */
QFrame#Card, QFrame[card="true"] {
    background: #FFFFFF;
    border: 1px solid #E8E6E0;
    border-radius: 16px;         /* Larger radius matching inspiration */
    padding: 4px;                /* Slight padding for shadow effect */
}

/* Inputs with subtle depth and warmth */
QLineEdit, QPlainTextEdit, QTextEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background: #FEFDFB;         /* Slightly warm white */
    border: 1px solid #E0DDD5;
    border-radius: 12px;         /* More rounded */
    padding: 8px 12px;           /* More generous padding */
}
QComboBox { min-height: 32px; }
QLineEdit:hover, QPlainTextEdit:hover, QTextEdit:hover, QSpinBox:hover, QDoubleSpinBox:hover, QComboBox:hover {
    border-color: #B0B4BA;
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border: 2px solid #F9A51B;
    padding: 5px 9px;    /* Compensate for thicker border */
    background: #FFFDF8;  /* Subtle warm tint when focused */
}

/* Buttons (default) with more rounded, pill-like aesthetic */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #FFFFFF, stop:1 #F8F7F5);   /* Warm gradient */
    border: 1px solid #E0DDD5;
    border-radius: 12px;         /* More rounded matching inspiration */
    padding: 10px 16px;          /* More generous padding */
    min-height: 36px;            /* Taller buttons */
    font-weight: 500;
}
QPushButton:hover { 
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #FFFFFF, stop:1 #F0F1F3);
    border-color: #B0B4BA;
}
QPushButton:pressed { 
    background: #E8EAED;
    border-color: #A0A4AA;
}
QPushButton:disabled { 
    background: #F2F3F5;
    color: #919A9F;
    border-color: #E0E2E5;
}

/* Compact buttons for table cells */
QTableWidget QPushButton {
    padding: 4px 8px;
    min-height: 24px;
    max-height: 28px;
    font-size: 12px;
    border-radius: 6px;
}
QTableWidget QPushButton[variant="primary"] {
    padding: 4px 8px;
    min-height: 24px;
    max-height: 28px;
}

/* Compact buttons for action rows (below tables, toolbars, etc) */
QPushButton#CompactButton {
    padding: 6px 10px;
    min-height: 28px;
    max-height: 32px;
    font-size: 12px;
}

QWidget#TableActionBar {
    padding-top: 8px;
}

/* Primary CTA with vibrant gradient */
QPushButton[variant="primary"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #FDB64E, stop:1 #F9A51B);   /* Warm gradient */
    border: 1px solid #F9A51B;
    color: #131313;
    font-weight: 600;
}
QPushButton[variant="primary"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #FEC668, stop:1 #FAB534);   /* Lighter on hover */
    border-color: #FAB534;
}
QPushButton[variant="primary"]:pressed {
    background: #F09210;
    border-color: #F09210;
}
QPushButton[variant="primary"]:disabled {
    background: #E7C37A;
    border-color: #E7C37A;
    color: #3A3A3A;
}

/* Danger (destructive) */
QPushButton[variant="danger"] {
    background: #D9534F;
    border: 1px solid #D9534F;
    color: #FFFFFF;
}
QPushButton[variant="danger"]:hover {
    background: #C94441;
    border-color: #C94441;
}

/* Tabs and headers with depth and warmth */
QTabWidget::pane {
    border: 1px solid #E8E6E0;
    border-radius: 12px;
    background: #FFFFFF;
    margin-top: 4px;         /* Space between tabs and content */
}
QTabBar::tab {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FEFDFB, stop:1 #F5F3EF);   /* Warm gradient */
    border: 1px solid #E8E6E0;
    border-bottom: none;
    padding: 10px 20px;          /* More generous padding */
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    margin-right: 3px;           /* More spacing between tabs */
    font-weight: 500;
}
QTabBar::tab:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FFFFFF, stop:1 #F8F7F5);
}
QTabBar::tab:selected {
    background: #FFFFFF;
    border-bottom-color: #FFFFFF;
    font-weight: 700;            /* Bolder when selected */
}

/* Tables with warmth */
QHeaderView::section {
    background: #FEFDFB;
    border: 1px solid #E8E6E0;
    padding: 10px 12px;          /* More padding */
    font-weight: 600;
}
QTableView, QTableWidget {
    background: #FFFFFF;
    border: 1px solid #E8E6E0;
    border-radius: 12px;         /* More rounded */
    gridline-color: #F0EEE8;     /* Lighter gridlines */
}
QTableView::item:selected, QTableWidget::item:selected {
    background: #EDE7D9; /* subtle selection that fits palette */
    color: #131313;
}

/* Progress bars */
QProgressBar {
    border: 1px solid #DBDBD9;
    border-radius: 8px;
    text-align: center;
    background: #FFFFFF;
}
QProgressBar::chunk {
    background-color: #FAC95A;
    border-radius: 8px;
}

/* Group boxes as elevated cards with generous spacing */
QGroupBox {
    background: #FFFFFF;
    border: 1px solid #E8E6E0;
    border-radius: 16px;         /* Larger radius matching inspiration */
    margin-top: 20px;            /* More space for title */
    margin-bottom: 12px;         /* Space between cards */
    padding: 28px 20px 20px 20px; /* More generous padding all around */
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;              /* horizontal position within margin */
    top: 6px;                /* vertical offset to sit properly in margin */
    padding: 0 8px;          /* more padding around text */
    color: #131313;          /* Darker for better readability */
    font-weight: 700;        /* Bolder titles */
    font-size: 14px;         /* Larger titles */
    background: transparent;
}

/* Nested QGroupBox (inside another QGroupBox) - warm subtle styling */
QGroupBox QGroupBox {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FEFDFB, stop:1 #FAF9F7);     /* Warm subtle gradient */
    border: 1px solid #EAE7E0;
    border-radius: 12px;         /* More rounded */
    margin-top: 16px;
    padding: 24px 16px 16px 16px; /* More generous padding */
}
QGroupBox QGroupBox::title {
    color: #131313;          /* Same as parent for consistency */
    font-weight: 600;
    font-size: 12px;
    left: 8px;
    top: 2px;
}

/* Lists with hover states and warmth */
QListWidget {
    background: #FFFFFF;
    border: 1px solid #E8E6E0;
    border-radius: 12px;         /* More rounded */
    padding: 8px;                /* More padding */
}
QListWidget::item { 
    padding: 8px 10px;
    border-radius: 6px;
}
QListWidget::item:hover {
    background: #F5F6F8;
}
QListWidget::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FFF3D9, stop:1 #FFE8B8);    /* Warm selection */
    color: #131313;
    font-weight: 500;
}

/* Scrollbars: minimal for performance */
QScrollBar:vertical {
    background: transparent;
    width: 10px;
}
QScrollBar::handle:vertical {
    background: #DBDBD9;
    border-radius: 5px;
    min-height: 24px;
}
QScrollBar:horizontal {
    background: transparent;
    height: 10px;
}
QScrollBar::handle:horizontal {
    background: #DBDBD9;
    border-radius: 5px;
    min-width: 24px;
}
QScrollBar::add-line, QScrollBar::sub-line { width: 0; height: 0; }

/* Drop area states */
QWidget#DropArea[state="idle"] {
    background: #FFFFFF;
    border: 2px dashed #DBDBD9;
    border-radius: 10px;
}
QWidget#DropArea[state="drag"] {
    background: #FFF8E8;          /* soft highlight */
    border: 3px solid #F9A51B;
    border-radius: 10px;
}

/* Wizard visuals */
QLabel#Subheader {
    color: #919A9F;
    padding: 6px 0;
}
QTextEdit#WizardLog {
    background: #F5F5F5;
    border: 1px solid #DBDBD9;
    border-radius: 8px;
}
QLabel[variant="warning"] {
    background: #FFF3E0;
    color: #8A4B00;
    padding: 8px 10px;
    border-radius: 8px;
}
QLabel[variant="success"] {
    color: #2E7D32;
    font-weight: 600;
}
QLabel#ChecklistItem {
    padding: 6px 4px;
}

/* UserTab specific styles */
QLabel#InfoBanner {
    background: #FFF8E8;
    color: #8A4B00;
    padding: 12px;
    border-radius: 8px;
}
QLabel#ProfileWelcome {
    font-size: 16px;
    font-weight: 600;
    padding: 8px 0;
}
QLabel#LinkLabel {
    color: #F9A51B;
    font-size: 11px;
}
QLabel#LinkLabel:hover {
    text-decoration: underline;
}

/* Help text styling (used in forms) */
QLabel#HelpText {
    color: #5f6368;          /* Darker for better readability */
    font-size: 12px;
    padding: 4px 0;
    line-height: 1.4;
}

/* Status labels for priming widget */
QLabel#StatusLabel {
    border-radius: 8px;
    padding: 8px 12px;
    font-weight: 600;
    font-size: 13px;
}
QLabel#StatusLabel[status="closed"] {
    background: #E6E6E3;
    color: #919A9F;
}
QLabel#StatusLabel[status="open"] {
    background: #4CAF50;
    color: #FFFFFF;
}

/* Form labels within QGroupBox - ensure proper contrast */
QGroupBox QLabel {
    background: transparent;  /* Inherit parent background */
}
QGroupBox QFormLayout QLabel {
    padding: 4px 0;
}


