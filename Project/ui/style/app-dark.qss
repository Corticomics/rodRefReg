/* 
 * Rodent Refreshment Regulator - Dark Theme
 * RSO-Inspired Design System with Teal Accent
 * 
 * Design Principles:
 * - IBM Plex Sans typography for scientific aesthetic
 * - Teal accent color (brightened for dark mode)
 * - Material Design 3 elevation system
 * - WCAG 2.1 AA contrast compliance
 * 
 * Color Palette (Dark Mode):
 * - Primary Accent: #14B8A6 (Teal 500)
 * - Primary Hover: #2DD4BF (Teal 400)
 * - Background: #0F1419 / #1A2028
 * - Text Primary: #F0F4F8 (high contrast)
 * - Text Secondary: #A0AEC0
 */

/* ============================================
   GLOBAL DEFAULTS
   ============================================ */
* {
    font-family: "IBM Plex Sans", "SF Pro Display", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 13px;
    outline: none;
}

QWidget {
    background-color: #1A2028;
    color: #F0F4F8;
}

/* Main window background */
QMainWindow {
    background-color: #0F1419;
}

/* ============================================
   CARDS & ELEVATED SURFACES
   ============================================ */
QFrame#Card, QFrame[card="true"] {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 12px;
    padding: 0;
}
QFrame#Card:hover, QFrame[card="true"]:hover {
    border-color: #4A5568;
}

/* ============================================
   TYPOGRAPHY HELPERS
   ============================================ */
QLabel#Headline {
    font-size: 24px;
    font-weight: 600;
    color: #F0F4F8;
}
QLabel#Title {
    font-size: 18px;
    font-weight: 500;
    color: #F0F4F8;
}
QLabel#Subtitle, QLabel#Subheader {
    font-size: 14px;
    font-weight: 400;
    color: #A0AEC0;
    padding: 4px 0;
}
QLabel#Caption {
    font-size: 11px;
    color: #718096;
}

/* ============================================
   FORM INPUTS
   ============================================ */
QLineEdit, QPlainTextEdit, QTextEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 8px;
    padding: 10px 12px;
    color: #F0F4F8;
    selection-background-color: #14B8A6;
    selection-color: #1A1D1F;
}
QComboBox { 
    min-height: 36px;
    padding-right: 28px;
}
QLineEdit:hover, QPlainTextEdit:hover, QTextEdit:hover, 
QSpinBox:hover, QDoubleSpinBox:hover, QComboBox:hover {
    border-color: #4A5568;
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus, 
QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border: 2px solid #14B8A6;
    padding: 9px 11px;
    background: #242C38;
}
QLineEdit:disabled, QSpinBox:disabled, QDoubleSpinBox:disabled, QComboBox:disabled {
    background: #1A2028;
    color: #4A5568;
    border-color: #2D3748;
}

/* Placeholder text */
QLineEdit[placeholderText] {
    color: #718096;
}

/* ComboBox dropdown */
QComboBox::drop-down {
    border: none;
    width: 24px;
    padding-right: 8px;
}
QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #A0AEC0;
}
QComboBox QAbstractItemView {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 8px;
    padding: 4px;
    selection-background-color: #134E4A;
    selection-color: #2DD4BF;
}

/* SpinBox buttons */
QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    background: transparent;
    border: none;
    width: 20px;
}

/* ============================================
   BUTTONS - Default
   ============================================ */
QPushButton {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 8px;
    padding: 10px 20px;
    min-height: 40px;
    font-weight: 500;
    color: #F0F4F8;
}
QPushButton:hover { 
    background: #242C38;
    border-color: #4A5568;
}
QPushButton:pressed { 
    background: #2A3441;
    border-color: #4A5568;
}
QPushButton:disabled { 
    background: #1A2028;
    color: #4A5568;
    border-color: #2D3748;
}
QPushButton:focus {
    border: 2px solid #14B8A6;
    padding: 9px 19px;
}

/* Compact buttons for tables */
QTableWidget QPushButton {
    padding: 6px 12px;
    min-height: 28px;
    max-height: 32px;
    font-size: 12px;
    border-radius: 6px;
}

QPushButton#CompactButton {
    padding: 8px 12px;
    min-height: 32px;
    max-height: 36px;
    font-size: 12px;
}

/* ============================================
   BUTTONS - Primary (Teal - Brightened)
   ============================================ */
QPushButton[variant="primary"] {
    background: #14B8A6;
    border: 1px solid #14B8A6;
    color: #042F2E;
    font-weight: 600;
}
QPushButton[variant="primary"]:hover {
    background: #2DD4BF;
    border-color: #2DD4BF;
}
QPushButton[variant="primary"]:pressed {
    background: #5EEAD4;
    border-color: #5EEAD4;
}
QPushButton[variant="primary"]:disabled {
    background: #134E4A;
    border-color: #134E4A;
    color: #5EEAD4;
}
QPushButton[variant="primary"]:focus {
    border: 2px solid #5EEAD4;
}

/* ============================================
   BUTTONS - Danger
   ============================================ */
QPushButton[variant="danger"] {
    background: #EF4444;
    border: 1px solid #EF4444;
    color: #FFFFFF;
    font-weight: 600;
}
QPushButton[variant="danger"]:hover {
    background: #F87171;
    border-color: #F87171;
}
QPushButton[variant="danger"]:pressed {
    background: #DC2626;
    border-color: #DC2626;
}

/* ============================================
   TABS
   ============================================ */
QTabWidget::pane {
    border: 1px solid #2D3748;
    border-radius: 12px;
    background: #1E2530;
    margin-top: -1px;
}
QTabBar::tab {
    background: #1A2028;
    border: 1px solid #2D3748;
    border-bottom: none;
    padding: 10px 20px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    margin-right: 2px;
    font-size: 13px;
    font-weight: 500;
    color: #A0AEC0;
}
QTabBar::tab:hover {
    background: #1E2530;
    color: #F0F4F8;
}
QTabBar::tab:selected {
    background: #1E2530;
    border-bottom-color: #1E2530;
    color: #14B8A6;
    font-weight: 600;
}

/* ============================================
   TABLES
   ============================================ */
QHeaderView::section {
    background: #1A2028;
    border: none;
    border-bottom: 2px solid #2D3748;
    padding: 12px 16px;
    font-weight: 600;
    color: #A0AEC0;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.5px;
}
QTableView, QTableWidget {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 12px;
    gridline-color: #242C38;
    selection-background-color: #134E4A;
    selection-color: #2DD4BF;
    color: #F0F4F8;
}
QTableView::item, QTableWidget::item {
    padding: 12px 16px;
    border-bottom: 1px solid #242C38;
}
QTableView::item:selected, QTableWidget::item:selected {
    background: #134E4A;
    color: #2DD4BF;
}
QTableView::item:hover, QTableWidget::item:hover {
    background: #242C38;
}

/* ============================================
   PROGRESS BARS
   ============================================ */
QProgressBar {
    border: none;
    border-radius: 8px;
    text-align: center;
    background: #2D3748;
    min-height: 8px;
    max-height: 8px;
}
QProgressBar::chunk {
    background: #14B8A6;
    border-radius: 8px;
}

/* Larger progress bar variant */
QProgressBar#DeliveryProgress {
    min-height: 24px;
    max-height: 24px;
    font-size: 12px;
    font-weight: 600;
    color: #042F2E;
}
QProgressBar#DeliveryProgress::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                              stop:0 #0D9488, stop:1 #14B8A6);
}

/* ============================================
   GROUP BOXES (Cards)
   ============================================ */
QGroupBox {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 12px;
    margin-top: 24px;
    margin-bottom: 8px;
    padding: 24px 20px 20px 20px;
    color: #F0F4F8;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 16px;
    top: 8px;
    padding: 0 8px;
    color: #F0F4F8;
    font-weight: 600;
    font-size: 14px;
    background: transparent;
}

/* Nested GroupBox */
QGroupBox QGroupBox {
    background: #242C38;
    border: 1px solid #2D3748;
    border-radius: 8px;
    margin-top: 20px;
    padding: 20px 16px 16px 16px;
}
QGroupBox QGroupBox::title {
    color: #A0AEC0;
    font-weight: 500;
    font-size: 12px;
}

/* ============================================
   LISTS
   ============================================ */
QListWidget {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 8px;
    padding: 8px;
    color: #F0F4F8;
}
QListWidget::item { 
    padding: 10px 12px;
    border-radius: 6px;
    margin: 2px 0;
}
QListWidget::item:hover {
    background: #242C38;
}
QListWidget::item:selected {
    background: #134E4A;
    color: #2DD4BF;
    font-weight: 500;
}

/* ============================================
   SCROLLBARS (Minimal)
   ============================================ */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 4px 2px;
}
QScrollBar::handle:vertical {
    background: #4A5568;
    border-radius: 4px;
    min-height: 32px;
}
QScrollBar::handle:vertical:hover {
    background: #718096;
}
QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 2px 4px;
}
QScrollBar::handle:horizontal {
    background: #4A5568;
    border-radius: 4px;
    min-width: 32px;
}
QScrollBar::handle:horizontal:hover {
    background: #718096;
}
QScrollBar::add-line, QScrollBar::sub-line,
QScrollBar::add-page, QScrollBar::sub-page { 
    background: transparent;
    width: 0; 
    height: 0; 
}

/* ============================================
   DROP AREAS
   ============================================ */
QWidget#DropArea[state="idle"] {
    background: #1E2530;
    border: 2px dashed #4A5568;
    border-radius: 12px;
}
QWidget#DropArea[state="drag"] {
    background: #134E4A;
    border: 2px solid #14B8A6;
    border-radius: 12px;
}

/* ============================================
   STATUS INDICATORS
   ============================================ */
QLabel[variant="warning"] {
    background: #78350F;
    color: #FDE68A;
    padding: 12px 16px;
    border-radius: 8px;
    border-left: 4px solid #F59E0B;
}
QLabel[variant="success"] {
    background: #064E3B;
    color: #A7F3D0;
    padding: 12px 16px;
    border-radius: 8px;
    border-left: 4px solid #10B981;
}
QLabel[variant="error"] {
    background: #7F1D1D;
    color: #FECACA;
    padding: 12px 16px;
    border-radius: 8px;
    border-left: 4px solid #EF4444;
}
QLabel[variant="info"] {
    background: #0C4A6E;
    color: #BAE6FD;
    padding: 12px 16px;
    border-radius: 8px;
    border-left: 4px solid #0284C7;
}

/* ============================================
   USER TAB STYLES
   ============================================ */
QLabel#InfoBanner {
    background: #134E4A;
    color: #2DD4BF;
    padding: 12px 16px;
    border-radius: 8px;
    border-left: 4px solid #14B8A6;
}
QLabel#ProfileWelcome {
    font-size: 18px;
    font-weight: 600;
    padding: 8px 0;
    color: #F0F4F8;
}
QLabel#LinkLabel {
    color: #2DD4BF;
    font-size: 12px;
}
QLabel#LinkLabel:hover {
    text-decoration: underline;
    color: #5EEAD4;
}

/* ============================================
   HELP TEXT
   ============================================ */
QLabel#HelpText {
    color: #A0AEC0;
    font-size: 12px;
    padding: 4px 0;
    line-height: 1.5;
}

/* ============================================
   PRIMING STATUS
   ============================================ */
QLabel#StatusLabel {
    border-radius: 8px;
    padding: 10px 16px;
    font-weight: 600;
    font-size: 13px;
}
QLabel#StatusLabel[status="closed"] {
    background: #2D3748;
    color: #A0AEC0;
}
QLabel#StatusLabel[status="open"] {
    background: #14B8A6;
    color: #042F2E;
}

/* ============================================
   FORM LAYOUTS
   ============================================ */
QGroupBox QLabel {
    background: transparent;
    color: #F0F4F8;
}
QFormLayout > QLabel {
    min-width: 160px;
    padding-right: 12px;
    color: #A0AEC0;
    font-weight: 500;
}

/* ============================================
   SCHEDULE PROGRESS TRACKER
   ============================================ */

/* Header frame */
QFrame#TrackerHeader {
    background-color: #242C38;
    border: 1px solid #2D3748;
    border-radius: 12px;
    padding: 12px;
}

QLabel#ScheduleTitle {
    font-size: 16px;
    font-weight: 600;
    color: #F0F4F8;
    background: transparent;
}

QLabel#ElapsedTime {
    font-size: 14px;
    font-weight: 500;
    color: #2DD4BF;
    background: #134E4A;
    padding: 6px 12px;
    border-radius: 16px;
}

QScrollArea#TrackerScrollArea {
    background-color: transparent;
    border: none;
}

/* Material Cards */
QFrame#MaterialCard {
    background-color: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 12px;
    padding: 0;
}
QFrame#MaterialCard:hover {
    border-color: #4A5568;
    background-color: #242C38;
}

QLabel#CardTitle {
    font-size: 15px;
    font-weight: 600;
    color: #F0F4F8;
    background: transparent;
}

QLabel#CageBadge {
    background-color: #14B8A6;
    color: #042F2E;
    padding: 6px 12px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 11px;
}

/* ============================================
   CAGES VISUALIZATION TAB
   ============================================ */

/* Board title - centered, subtle */
QLabel#BoardTitle {
    font-size: 12px;
    font-weight: 500;
    color: #718096;
    background: transparent;
    padding: 4px 0;
}

/* Column headers - uppercase, subtle */
QLabel#ColumnHeader {
    font-size: 10px;
    font-weight: 600;
    color: #718096;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    background: transparent;
    padding: 6px 0;
}

/* Relay Terminal Widget - cage type */
QFrame#RelayTerminal {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 6px;
    border-left: 3px solid #14B8A6;
}
QFrame#RelayTerminal:hover {
    background: #134E4A;
    border-color: #4A5568;
}
QFrame#RelayTerminal[selected="true"] {
    background: #134E4A;
    border-color: #14B8A6;
}

/* Relay Terminal Widget - master solenoid */
QFrame#MasterTerminal {
    background: #451A03;
    border: 1px solid #78350F;
    border-radius: 6px;
    border-left: 3px solid #F59E0B;
}
QFrame#MasterTerminal:hover {
    background: #78350F;
}
QFrame#MasterTerminal[selected="true"] {
    background: #78350F;
    border-color: #FBBF24;
}

/* Inline cage name editor */
QLineEdit#CageNameEdit {
    background: #242C38;
    border: 1px solid #14B8A6;
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 13px;
    font-weight: 500;
    color: #F0F4F8;
}

/* Relay number badge */
QLabel#RelayNumber {
    font-size: 12px;
    font-weight: 700;
    color: #E2E8F0;
    background: #2D3748;
    border-radius: 4px;
    padding: 2px 6px;
}

/* Cage name - primary text */
QLabel#CageNameLabel {
    font-size: 13px;
    font-weight: 500;
    color: #F0F4F8;
    background: transparent;
}

/* Master label - amber accent */
QLabel#MasterLabel {
    font-size: 12px;
    font-weight: 700;
    color: #FCD34D;
    background: transparent;
}

/* Unassigned relay */
QLabel#UnassignedLabel {
    font-size: 12px;
    color: #718096;
    background: transparent;
}

/* Status indicator dots */
QLabel#StatusDot {
    font-size: 10px;
    color: #2DD4BF;
    background: transparent;
}

QLabel#MasterStatusDot {
    font-size: 10px;
    color: #FBBF24;
    background: transparent;
}

QLabel#VolumeLabel {
    font-size: 14px;
    font-weight: 600;
    color: #F0F4F8;
    background: transparent;
}

QLabel#StatusLabel {
    font-size: 12px;
    color: #A0AEC0;
    background: transparent;
}

QLabel#HealthIndicator {
    font-size: 11px;
    color: #718096;
    background: transparent;
}

QLabel#TimeRemaining {
    font-size: 11px;
    color: #718096;
    font-style: italic;
    background: transparent;
}

/* ============================================
   WIZARD LOG
   ============================================ */
QTextEdit#WizardLog {
    background: #242C38;
    border: 1px solid #2D3748;
    border-radius: 8px;
    font-family: "IBM Plex Mono", "SF Mono", Monaco, monospace;
    font-size: 12px;
    padding: 12px;
    color: #F0F4F8;
}

QLabel#ChecklistItem {
    padding: 8px 4px;
}

/* ============================================
   TABLE ACTION BAR
   ============================================ */
QWidget#TableActionBar {
    padding: 12px 0;
}

/* ============================================
   CHECKBOXES
   ============================================ */
QCheckBox {
    spacing: 8px;
    color: #F0F4F8;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #4A5568;
    border-radius: 4px;
    background: #1E2530;
}
QCheckBox::indicator:hover {
    border-color: #14B8A6;
}
QCheckBox::indicator:checked {
    background: #14B8A6;
    border-color: #14B8A6;
}
QCheckBox::indicator:disabled {
    background: #1A2028;
    border-color: #2D3748;
}

/* ============================================
   RADIO BUTTONS
   ============================================ */
QRadioButton {
    spacing: 8px;
    color: #F0F4F8;
}
QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #4A5568;
    border-radius: 9px;
    background: #1E2530;
}
QRadioButton::indicator:hover {
    border-color: #14B8A6;
}
QRadioButton::indicator:checked {
    background: #14B8A6;
    border-color: #14B8A6;
}

/* ============================================
   TOOLTIPS
   ============================================ */
QToolTip {
    background: #F0F4F8;
    color: #1A1D1F;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 12px;
}

/* ============================================
   MENU BAR
   ============================================ */
QMenuBar {
    background: #1E2530;
    border-bottom: 1px solid #2D3748;
    padding: 4px 8px;
}
QMenuBar::item {
    padding: 8px 12px;
    border-radius: 6px;
    color: #F0F4F8;
}
QMenuBar::item:selected {
    background: #242C38;
}
QMenu {
    background: #1E2530;
    border: 1px solid #2D3748;
    border-radius: 8px;
    padding: 8px;
}
QMenu::item {
    padding: 10px 24px;
    border-radius: 6px;
    color: #F0F4F8;
}
QMenu::item:selected {
    background: #134E4A;
    color: #2DD4BF;
}

/* ============================================
   SLIDERS
   ============================================ */
QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #2D3748;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #14B8A6;
    border: none;
    width: 18px;
    height: 18px;
    margin: -6px 0;
    border-radius: 9px;
}
QSlider::handle:horizontal:hover {
    background: #2DD4BF;
}
QSlider::sub-page:horizontal {
    background: #14B8A6;
    border-radius: 3px;
}

/* ============================================
   WIZARD COMPONENTS (Dark Theme)
   ============================================ */

/* Wizard Step Circle */
QLabel#WizardStepCircle {
    font-size: 14px;
    font-weight: 600;
    border-radius: 18px;
    border: 2px solid #4A5568;
    background: #242C38;
    color: #8492A6;
}
QLabel#WizardStepCircle[state="completed"] {
    border-color: #14B8A6;
    background: #14B8A6;
    color: #1A2028;
}
QLabel#WizardStepCircle[state="current"] {
    border-color: #14B8A6;
    background: #134E4A;
    color: #2DD4BF;
}
QLabel#WizardStepCircle[state="pending"] {
    border-color: #4A5568;
    background: #242C38;
    color: #718096;
}

/* Wizard Step Title */
QLabel#WizardStepTitle {
    font-size: 11px;
    color: #718096;
    padding: 0 8px;
}
QLabel#WizardStepTitle[state="completed"] {
    color: #14B8A6;
}
QLabel#WizardStepTitle[state="current"] {
    color: #F0F4F8;
    font-weight: 600;
}

/* Wizard Connector Line */
QFrame#WizardConnector {
    background: #4A5568;
    border: none;
}
QFrame#WizardConnector[state="completed"] {
    background: #14B8A6;
}

/* Wizard Separator */
QFrame#WizardSeparator {
    background: #2D3748;
    max-height: 1px;
}

/* Wizard Navigation Buttons */
QPushButton#WizardBackButton {
    background: #242C38;
    border: 1px solid #4A5568;
    border-radius: 10px;
    color: #A0AEC0;
    padding: 12px 20px;
    font-size: 14px;
    font-weight: 500;
}
QPushButton#WizardBackButton:hover {
    background: #2D3748;
    border-color: #718096;
    color: #F0F4F8;
}
QPushButton#WizardNextButton {
    background: #14B8A6;
    border: none;
    border-radius: 10px;
    color: #1A2028;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
}
QPushButton#WizardNextButton:hover {
    background: #2DD4BF;
}
QPushButton#WizardNextButton:disabled {
    background: #4A5568;
    color: #718096;
}

/* ============================================
   INTERACTIVE CARD COMPONENT (Dark Theme)
   ============================================ */
QFrame#InteractiveCard {
    background: #1E2530;
    border: 2px solid #2D3748;
    border-radius: 12px;
    padding: 16px;
}
QFrame#InteractiveCard:hover {
    border-color: #14B8A6;
    background: #134E4A;
}
QFrame#InteractiveCard[checked="true"] {
    border-color: #14B8A6;
    background: #134E4A;
}

/* Card Icon */
QLabel#CardIcon {
    font-size: 20px;
    color: #2DD4BF;
    background: #134E4A;
    border-radius: 8px;
}

/* Card Title */
QLabel#CardTitle {
    font-size: 16px;
    font-weight: 600;
    color: #F0F4F8;
}

/* Card Description */
QLabel#CardDescription {
    font-size: 13px;
    color: #A0AEC0;
    line-height: 1.4;
}

/* Card Badge */
QLabel#CardBadge {
    font-size: 11px;
    font-weight: 500;
    color: #2DD4BF;
    background: #134E4A;
    border-radius: 6px;
    padding: 4px 8px;
}

/* ============================================
   WIZARD STEP CONTENT AREA (Dark Theme)
   ============================================ */
QWidget#WizardStepContent {
    background: #1A2028;
    padding: 24px;
}

/* Step Header */
QLabel#StepIcon {
    font-size: 24px;
    color: #2DD4BF;
}
QLabel#StepTitle {
    font-size: 22px;
    font-weight: 600;
    color: #F0F4F8;
}
QLabel#StepDescription {
    font-size: 14px;
    color: #A0AEC0;
}
